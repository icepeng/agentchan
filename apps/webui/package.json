{
  "name": "@agentchan/webui",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun run src/server/index.ts",
    "build:exe": "bun run scripts/build-exe.ts",
    "build:exe:linux": "bun run scripts/build-exe.ts --target=bun-linux-x64",
    "build:exe:mac": "bun run scripts/build-exe.ts --target=bun-darwin-arm64",
    "build:exe:win": "bun run scripts/build-exe.ts --target=bun-windows-x64",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@agentchan/creative-agent": "workspace:*",
    "@agentchan/estimate-tokens": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "hono": "^4.7.0",
    "idiomorph": "^0.7.4",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  }
}
