{
  "name": "@agentchan/webui",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "portless run --name agentchan turbo run dev:server dev:client --filter=@agentchan/webui --env-mode=loose",
    "dev:local": "turbo run dev:server dev:client --filter=@agentchan/webui --env-mode=loose",
    "dev:server": "cd ../.. && bun apps/webui/scripts/kill-dev-port.ts server && bun --hot apps/webui/scripts/dev-server.ts",
    "dev:client": "bun scripts/kill-dev-port.ts client && vite",
    "build": "vite build",
    "start": "bun run src/server/index.ts",
    "build:exe": "bun run scripts/build-exe.ts",
    "build:exe:linux": "bun run scripts/build-exe.ts --target=bun-linux-x64",
    "build:exe:mac": "bun run scripts/build-exe.ts --target=bun-darwin-arm64",
    "build:exe:win": "bun run scripts/build-exe.ts --target=bun-windows-x64",
    "test": "bun test src"
  },
  "dependencies": {
    "@agentchan/creative-agent": "workspace:*",
    "@agentchan/estimate-tokens": "workspace:*",
    "@agentchan/renderer": "workspace:*",
    "@agentchan/renderer-build": "workspace:*",
    "@base-ui/react": "^1.4.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lezer/highlight": "^1.2.3",
    "@mariozechner/pi-ai": "^0.70.2",
    "command-score": "^0.1.2",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "scheduler": "^0.27.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
