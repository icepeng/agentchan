#!/usr/bin/env sh

# Linked worktrees have a .git file that points at the common Git dir.
[ -f .git ] || exit 0

# New worktrees are created by an initial branch checkout:
# old HEAD is all zeros and the checkout flag is 1.
case "$1:$3" in
  0000000000000000000000000000000000000000:1)
    bun scripts/setup-worktree.ts
    ;;
esac
