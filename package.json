{
  "name": "agentchan",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:exe": "bun run --cwd apps/webui build:exe",
    "build:exe:linux": "bun run --cwd apps/webui build:exe:linux",
    "build:exe:mac": "bun run --cwd apps/webui build:exe:mac",
    "build:exe:win": "bun run --cwd apps/webui build:exe:win",
    "test": "turbo run test",
    "dev": "bun run --cwd apps/webui dev",
    "lint": "oxlint apps/webui/src packages/creative-agent/src --type-aware",
    "typecheck": "bun run typecheck:packages && bun run typecheck:scripts",
    "typecheck:packages": "bun --workspaces run typecheck",
    "typecheck:scripts": "tsgo --noEmit -p tsconfig.scripts.json",
    "sync-builtins": "bun scripts/write-builtin-manifest.ts",
    "prepare": "husky",
    "example-data:copy": "bun scripts/copy-example-data.ts",
    "skills:check": "bun scripts/sync-agent-skills.ts --check",
    "skills:sync": "bun scripts/sync-agent-skills.ts",
    "afk": "bun run scripts/afk/run.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "portless": "^0.12.0",
    "turbo": "^2.9.6",
    "@typescript/native-preview": "7.0.0-dev.20260501.1"
  },
  "packageManager": "bun@1.3.11"
}
