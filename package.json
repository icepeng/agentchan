{
  "name": "agentchan",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:exe": "bun run --cwd apps/webui build:exe",
    "build:exe:linux": "bun run --cwd apps/webui build:exe:linux",
    "build:exe:mac": "bun run --cwd apps/webui build:exe:mac",
    "build:exe:win": "bun run --cwd apps/webui build:exe:win",
    "test": "turbo run test",
    "dev": "bun run --cwd apps/webui dev",
    "lint": "turbo run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "portless": "^0.10.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "bun@1.3.11"
}